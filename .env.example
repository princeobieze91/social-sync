# ── Backend ─────────────────────────────────────────────────────
APP_SECRET=               # Secret for signing JWT sessions

# ── Database (Neon PostgreSQL) ──────────────────────────────────
DATABASE_URL=             # postgresql://user:pass@ep-xxx.us-east-2.aws.neon.tech/dbname?sslmode=require

# ── App URL ─────────────────────────────────────────────────────
APP_URL=                  # Public URL of this app (e.g. https://socialsync.onrender.com)

# ── Open-Dispatch (self-hosted social publishing) ──────────────
OPEN_DISPATCH_URL=        # URL of Open-Dispatch instance (e.g. http://localhost:8000)
